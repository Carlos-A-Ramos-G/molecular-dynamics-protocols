#!/bin/bash
#
# NVT production worker for LOCAL GPU execution (no SLURM).
# Runs CHUNKS_PER_JOB sequential chunks of prod1.in inside a single bash
# process, then recurses (via bash, not sbatch) for any remaining chunks.
# All placeholders (__START__, __CPJ__, __TOTAL__) are filled in by
# script.sh --local on first invocation and re-filled below for chained calls.
#
# __TOPOLOGY__ is substituted by run_upto_NVT.py at configure time.
# Do not edit this file after the driver has run; re-run the driver instead.

set -euo pipefail
cd "$(dirname "${BASH_SOURCE[0]}")"

# --- Configuration injected at submission time ---
START=__START__              # first chunk handled by THIS invocation (1-based)
CHUNKS_PER_JOB=__CPJ__       # chunks run sequentially in THIS invocation
TOTAL_CHUNKS=__TOTAL__       # total chunks for the whole production run

# Window of chunks this invocation is responsible for.
end=$((START + CHUNKS_PER_JOB - 1))
[ ${end} -gt ${TOTAL_CHUNKS} ] && end=${TOTAL_CHUNKS}

# Bootstrap: seed structure_NVT_0.rst7 from stage 03 on the very first chunk.
if [ ${START} -eq 1 ] && [ ! -f structure_NVT_0.rst7 ]; then
    cp ../03_equil/structure_equil_6.rst7 structure_NVT_0.rst7
fi

for ((i=START; i<=end; i++));do
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] NVT chunk ${i}/${TOTAL_CHUNKS} starting ..."
    pmemd.cuda -O -i prod1.in \
                  -o structure_NVT_${i}.out \
                  -p ../00_prep/__TOPOLOGY__ \
                  -c structure_NVT_$((i-1)).rst7 \
                  -r structure_NVT_${i}.rst7 \
                  -x structure_NVT_${i}.nc
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] NVT chunk ${i}/${TOTAL_CHUNKS} done."
done

# Chain the next batch of chunks sequentially (bash, not sbatch).
if [ ${end} -lt ${TOTAL_CHUNKS} ]; then
    next=$((end + 1))
    sed -e "s|__START__|${next}|g" \
        -e "s|__CPJ__|${CHUNKS_PER_JOB}|g" \
        -e "s|__TOTAL__|${TOTAL_CHUNKS}|g" \
        run_local_template > run_NVT_${next}_local.sh
    chmod +x run_NVT_${next}_local.sh
    bash run_NVT_${next}_local.sh
fi
