#!/bin/bash
#SBATCH --time=__WALLTIME_MASTER__
#SBATCH --nodes=1
#SBATCH --gres=gpu:1
#SBATCH --partition gpu
#SBATCH --job-name=__JOB_NAME__
#SBATCH --account=__ACCOUNT__
#
# Master submit script for stages 00 -> 03 (preparation, minimization,
# heating, equilibration). Stage 04_NVT is launched at the end as its
# own SLURM chain via 04_NVT/script.sh, so this job only needs the
# walltime to cover preparation + ~12 ns of equilibration.
#
# This file is GENERATED from run_gpu_template by run_upto_NVT.py.
# Do not edit run_gpu directly; edit run_gpu_template (or config.ini)
# and re-run the python driver.

module load __AMBER_MODULE__

cd "${SLURM_SUBMIT_DIR}"
DIR=$(pwd)

# ============================================================
# 00_prep -- topology / coordinates
# ============================================================
cd $DIR/00_prep
tleap -f leap_structure
__HMR_BLOCK__

# ============================================================
# 01_min -- minimization with on-the-fly convergence check
# ============================================================
cd $DIR/01_min
cp $DIR/00_prep/structure.rst7 structure_min_0.rst7

max_min_cycles=__MIN_CYCLES_CAP__
conv_thresh=__CONV_THRESH__
converged_cycle=0

for ((i=1; i<=${max_min_cycles}; i++));do
    pmemd.cuda -O -i min.in  -o structure_min_${i}.out -p ../00_prep/__TOPOLOGY__ \
                             -c structure_min_$((i-1)).rst7 \
                             -r structure_min_${i}.rst7 \
                             -ref structure_min_$((i-1)).rst7

    # Lowest RMS gradient reached anywhere in this minimization run.
    min_rms=$(awk '/NSTEP[[:space:]]+ENERGY[[:space:]]+RMS[[:space:]]+GMAX/ {getline; print $3}' \
                  structure_min_${i}.out | sort -g | head -n 1)

    converged=$(awk -v r="${min_rms:-9e99}" -v t="${conv_thresh}" \
                'BEGIN {print (r+0 < t+0) ? 1 : 0}')
    echo "01_min cycle ${i}: min RMS gradient = ${min_rms} kcal/mol/A  (converged=${converged})"

    if [ "${converged}" -eq 1 ]; then
        echo "01_min converged at cycle ${i} (RMS < ${conv_thresh} kcal/mol/A)"
        converged_cycle=${i}
        break
    fi
done

if [ "${converged_cycle}" -gt 0 ]; then
    min_cycles=${converged_cycle}
else
    echo "WARNING: 01_min did not converge within ${max_min_cycles} cycles; using last cycle."
    min_cycles=${max_min_cycles}
fi

# ============================================================
# 02_heat -- heat to target temperature
# ============================================================
cd $DIR/02_heat
pmemd.cuda -O -i heat_GPU.in -o structure_heat_GPU.out -p ../00_prep/__TOPOLOGY__ \
                             -c $DIR/01_min/structure_min_${min_cycles}.rst7 \
                             -r structure_heat_GPU.rst7 \
                             -x structure_heat_GPU.nc \
                             -ref $DIR/01_min/structure_min_${min_cycles}.rst7

# ============================================================
# 03_equil -- restraint ramp -> unrestrained NVT
# ============================================================
cd $DIR/03_equil
cp $DIR/02_heat/structure_heat_GPU.rst7 structure_equil_0.rst7

# equil_creator.py reads these env vars to build each cycle's mdin.
export EQUIL_TEMP=__TEMPERATURE__
export EQUIL_DT=__DT__
export EQUIL_NPT_STEPS=__EQUIL_NPT_STEPS__
export EQUIL_NVT_STEPS=__EQUIL_NVT_STEPS__

for ((i=1; i<=6; i++));do
    ./equil_creator.py $i > equil.in
    pmemd.cuda -O -i equil.in -o structure_equil_${i}.out -p ../00_prep/__TOPOLOGY__ \
                              -c structure_equil_$((i-1)).rst7 \
                              -r structure_equil_${i}.rst7 \
                              -x structure_equil_${i}.nc \
                              -ref structure_equil_$((i-1)).rst7
done

# ============================================================
# 04_NVT -- production launched as its own SLURM chain
# ============================================================
cd $DIR/04_NVT
cp $DIR/03_equil/structure_equil_6.rst7 structure_NVT_0.rst7
./script.sh __CHUNKS_PER_JOB__ __TOTAL_CHUNKS__ __WALLTIME_NVT__
